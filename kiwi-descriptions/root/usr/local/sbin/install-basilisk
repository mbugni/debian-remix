#!/bin/bash

# =================================================================
# Basilisk Browser System-Wide Installer for Linux
# Target: Debian/Ubuntu-based distributions (i686 / x86_64)
# =================================================================

# Configuration
VERSION="20260122224704"
URL="https://dl.basilisk-browser.org/basilisk-${VERSION}.linux-$(uname -m)-gtk2.tar.xz"
INSTALL_PATH="/opt/basilisk"
BINARY_LINK="/usr/local/bin/basilisk"
APP_ENTRY="/usr/share/applications/basilisk.desktop"

# Ensure the script is run as root
if [ "$EUID" -ne 0 ]; then 
  echo "Please run as root (use sudo)."
  exit 1
fi

echo "Starting Basilisk installation..."

# 1. Install required dependencies
echo "Step 1: Installing dependencies..."
apt-get update
apt-get install -y libdbus-glib-1-2 libxt6 wget xz-utils

# 2. Download and Extract
echo "Step 2: Downloading Basilisk $VERSION..."
TMP_FILE=$(mktemp /tmp/basilisk.XXXXXX.tar.xz)
wget -O "$TMP_FILE" "$URL"

if [ $? -ne 0 ]; then
    echo "Error: Download failed. Check your internet connection."
    exit 1
fi

echo "Step 3: Extracting files to $INSTALL_PATH..."
rm -rf "$INSTALL_PATH"
mkdir -p "$INSTALL_PATH"
tar -xvf "$TMP_FILE" -C "$INSTALL_PATH" --strip-components=1
rm "$TMP_FILE"

# 3. Create Executable Link
echo "Step 4: Creating symbolic link..."
ln -sf "$INSTALL_PATH/basilisk" "$BINARY_LINK"

# 4. Create Desktop Entry
echo "Step 5: Creating desktop menu entry..."
cat <<EOF > "$APP_ENTRY"
[Desktop Entry]
Version=1.0
Name=Basilisk
Comment=Lightweight UXP-based Web Browser
GenericName=Web Browser
Exec=$BINARY_LINK %u
Icon=$INSTALL_PATH/browser/icons/mozicon128.png
Terminal=false
Type=Application
MimeType=text/html;text/xml;application/xhtml+xml;application/xml;x-scheme-handler/http;x-scheme-handler/https;
Categories=Network;WebBrowser;
Keywords=Browser;Web;Classic;
EOF

# 5. Finalize
update-desktop-database /usr/share/applications/ 2>/dev/null
echo "------------------------------------------------"
echo "Installation successful!"
echo "You can launch the browser by typing 'basilisk' or via the Applications menu."
echo "------------------------------------------------"
 
